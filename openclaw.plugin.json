{
  "id": "openclaw-napcat",
  "name": "NapCat QQ Channel",
  "version": "2.0.0",
  "description": "OpenClaw 的 NapCat QQ 插件 / OpenClaw NapCat QQ plugin，独立人格主链、审批桥接、reflection 与 daily memory。",
  "channels": ["napcat"],
  "skills": ["skills/napcat-ops"],
  "capabilities": {
    "proactiveMessaging": true,
    "groupMonitoring": true,
    "autoIntervention": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "host": {
        "type": "string",
        "description": "NapCat WebSocket 主机地址，推荐 127.0.0.1"
      },
      "port": {
        "type": "number",
        "description": "NapCat WebSocket 端口，例如 3001"
      },
      "accessToken": {
        "type": "string",
        "description": "NapCat WebSocket access token，强烈建议设置"
      },
      "path": {
        "type": "string",
        "description": "NapCat WebSocket 路径，默认 /"
      },
      "monitorGroups": {
        "type": "array",
        "items": { "type": "number" },
        "description": "启用 periodic patrol 的白名单群号列表；空数组表示只响应 @"
      },
      "autoIntervene": {
        "type": "boolean",
        "default": true,
        "description": "是否启用白名单群自动巡检"
      },
      "autoInterveneKeywords": {
        "type": "array",
        "items": { "type": "string" },
        "description": "备用触发关键词列表；当前主判断仍由人格主链完成"
      },
      "autoIntervenePrompt": {
        "type": "string",
        "description": "给自动巡检的附加提示词"
      },
      "autoCheckIntervalMs": {
        "type": "number",
        "default": 30000,
        "description": "白名单群巡检时间间隔（毫秒）"
      },
      "autoCheckMessageThreshold": {
        "type": "number",
        "default": 10,
        "description": "白名单群消息累积阈值，达到即触发巡检"
      },
      "requireMention": {
        "type": "boolean",
        "default": false,
        "description": "是否要求显式 @ 才立即进入正式群聊回合"
      },
      "historyLimit": {
        "type": "number",
        "default": 20,
        "description": "插件侧历史上下文保留条数"
      },
      "rateLimitMs": {
        "type": "number",
        "default": 1000,
        "description": "QQ 消息发送节流（毫秒）"
      },
      "renderMarkdownToPlain": {
        "type": "boolean",
        "default": true,
        "description": "是否把 Markdown 压成纯文本再发送"
      },
      "multimodalImagesEnabled": {
        "type": "boolean",
        "default": true,
        "description": "是否启用图片摘要与问图能力"
      },
      "multimodalImageMaxCount": {
        "type": "number",
        "default": 3,
        "description": "单轮最多处理的图片数量"
      },
      "persona": {
        "type": "object",
        "additionalProperties": false,
        "description": "人格主链配置",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "是否启用 persona-core -> voice-organ 主链"
          },
          "coreAgentId": {
            "type": "string",
            "default": "persona-core",
            "description": "正式群聊主脑 agent ID"
          },
          "voiceAgentId": {
            "type": "string",
            "default": "voice-organ",
            "description": "表达器官 agent ID"
          },
          "voiceOnGroupOnly": {
            "type": "boolean",
            "default": true,
            "description": "是否仅在群聊使用 voice-organ"
          }
        }
      },
      "maintenance": {
        "type": "object",
        "additionalProperties": false,
        "description": "后台维护循环配置",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "是否启用后台维护循环"
          },
          "reflectionEnabled": {
            "type": "boolean",
            "default": true,
            "description": "是否自动消费 reflection backlog"
          },
          "reflectionIntervalMs": {
            "type": "number",
            "default": 300000,
            "description": "reflection 心跳间隔（毫秒）"
          },
          "reflectionBatchSize": {
            "type": "number",
            "default": 5,
            "description": "每次处理的 reflection sample 数量"
          },
          "dailyMemoryEnabled": {
            "type": "boolean",
            "default": true,
            "description": "是否自动沉淀 daily memory"
          },
          "dailyMemoryIntervalMs": {
            "type": "number",
            "default": 900000,
            "description": "daily memory 心跳间隔（毫秒）"
          },
          "dailyMemoryBatchSize": {
            "type": "number",
            "default": 2,
            "description": "每次处理的群数量"
          }
        }
      },
      "whitelistUserIds": {
        "type": "array",
        "items": {
          "oneOf": [
            { "type": "number" },
            { "type": "string" }
          ]
        },
        "description": "允许私聊机器人的 QQ 号列表；空数组表示不限制"
      },
      "admins": {
        "type": "array",
        "items": {
          "oneOf": [
            { "type": "number" },
            { "type": "string" }
          ]
        },
        "description": "管理员 QQ 列表；用于审批和控制面命令"
      },
      "disableCommandsForAgents": {
        "type": "array",
        "items": { "type": "string" },
        "description": "在 QQ 会话里禁用命令式输入的 agent 列表，推荐至少包含 persona-core 和 voice-organ"
      }
    },
    "required": ["host", "port"]
  },
  "uiHints": {
    "host": {
      "label": "NapCat Host",
      "placeholder": "127.0.0.1"
    },
    "port": {
      "label": "NapCat Port",
      "placeholder": "3001"
    },
    "accessToken": {
      "label": "Access Token",
      "sensitive": true
    },
    "monitorGroups": {
      "label": "Monitor Groups"
    },
    "autoCheckIntervalMs": {
      "label": "Patrol Interval (ms)",
      "placeholder": "30000"
    },
    "autoCheckMessageThreshold": {
      "label": "Patrol Threshold",
      "placeholder": "10"
    },
    "whitelistUserIds": {
      "label": "Direct Message Whitelist"
    },
    "admins": {
      "label": "Admins"
    }
  }
}
